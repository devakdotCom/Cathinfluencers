{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/server.cjs",
      "**/server.cjs.map",
      "**/*.map"
    ],
    "headers": [
      {
        "source": "/assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "Permissions-Policy",
            "value": "camera=(), microphone=(), geolocation=(), autoplay=(self \"https://www.youtube.com\" \"https://www.youtube-nocookie.com\"), fullscreen=(self \"https://www.youtube.com\" \"https://www.youtube-nocookie.com\")"
          },
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://api.cloudinary.com https://*.googleapis.com https://*.firebaseio.com wss://*.firebaseio.com https://firestore.googleapis.com; frame-src https://www.youtube.com https://www.youtube-nocookie.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
          }
        ]
      }
    ],
    "rewrites": [
      { "source": "/app", "destination": "/app.html" },
      { "source": "/directory", "destination": "/app.html" },
      { "source": "/register", "destination": "/app.html" },
      { "source": "/signup", "destination": "/app.html" },
      { "source": "/login", "destination": "/app.html" },
      { "source": "/portal", "destination": "/app.html" },
      { "source": "/portal-hub", "destination": "/app.html" },
      { "source": "/courses", "destination": "/app.html" },
      { "source": "/our-leaders", "destination": "/app.html" },
      { "source": "/excellence", "destination": "/app.html" },
      { "source": "/vox-group", "destination": "/app.html" },
      { "source": "/trainers", "destination": "/app.html" },
      { "source": "/madha-tv", "destination": "/app.html" },
      { "source": "/chronicles", "destination": "/app.html" },
      { "source": "/calendar-rsvp", "destination": "/app.html" },
      { "source": "/catholic-connect", "destination": "/app.html" },
      { "source": "/resources", "destination": "/app.html" },
      { "source": "/reset-password", "destination": "/app.html" },
      { "source": "/admin", "destination": "/app.html" },
      { "source": "/admin/**", "destination": "/app.html" },
      { "source": "/auth/**", "destination": "/app.html" },
      { "source": "/dashboard", "destination": "/app.html" },
      { "source": "/verify", "destination": "/app.html" },
      { "source": "/profile", "destination": "/app.html" },
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
