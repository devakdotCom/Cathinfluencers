# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"

# Firebase web application configuration.
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN="vox-ecclesiae.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="vox-ecclesiae"
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
# Leave blank when using the default Firestore database.
VITE_FIRESTORE_DATABASE_ID=""
VITE_API_BASE_URL=""
VITE_FIREBASE_APP_CHECK_SITE_KEY=""

# Optional free image hosting. Create a restricted unsigned upload preset in Cloudinary.
VITE_CLOUDINARY_CLOUD_NAME=""
VITE_CLOUDINARY_UNSIGNED_UPLOAD_PRESET=""

# Optional Madha TV YouTube source. A channel ID takes priority and uses the
# YouTube live_stream embed URL; otherwise the verified video ID is used.
VITE_MADHA_TV_YOUTUBE_VIDEO_ID="zv6LzAfuy6k"
VITE_MADHA_TV_YOUTUBE_CHANNEL_ID=""

# Backend Firebase Admin credentials. Prefer GOOGLE_APPLICATION_CREDENTIALS
# locally and workload identity on Cloud Run.
GOOGLE_APPLICATION_CREDENTIALS=""
ALLOWED_ORIGINS="http://localhost:3000,https://vox-ecclesiae.web.app"
PORT="3000"
FIREBASE_PROJECT_ID="vox-ecclesiae"
CREDENTIAL_SIGNING_SECRET="replace-with-at-least-32-random-characters"
APP_CHECK_ENFORCED="true"
